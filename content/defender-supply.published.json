    {
      "_id": "desu-ch-health-savings-account",
      "title": "Health Savings Account",
      "description": "Tax-free savings account for qualified medical expenses, available to employees enrolled in the HDHP.",
      "slug": "health-savings-account",
      "icon": "dollar-sign",
      "content": [
        {
          "_type": "block",
          "_key": "block-0",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-0",
              "text": "With a Health Savings Account (HSA), contributions and withdrawals for qualified medical expenses are tax-free.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-1",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-1",
              "text": "Your HSA can be used for qualified expenses for you, your spouse and/or tax dependent(s), even if they are not covered by your plan.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-2",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-2",
              "text": "If you are not enrolled in a HDHP but you have unused HSA funds from a previous account, those funds can still be used for qualified medical expenses.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-3",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-3",
              "text": "The annual maximum contribution limit to HSAs is set by the IRS each year.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-4",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-4",
              "text": "Must be enrolled in the HDHP plan to contribute to a Health Savings Account (HSA).",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-5",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-5",
              "text": "HSA is administered through Optum. Contact: 866-633-2446 | www.myuhc.com",
              "marks": []
            }
          ],
          "markDefs": []
        }
      ],
      "tables": [
        {
