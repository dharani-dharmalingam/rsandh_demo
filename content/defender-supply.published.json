    {
      "_id": "desu-ch-income-protection",
      "title": "Income Protection",
      "description": "Voluntary short-term and long-term disability coverage through Unum to protect your income during illness or injury.",
      "slug": "income-protection",
      "icon": "briefcase",
      "content": [
        {
          "_type": "block",
          "_key": "block-0",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-0",
              "text": "LEHR offers disability coverage to protect you financially in the event you cannot work due to a debilitating illness or injury.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-1",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-1",
              "text": "A portion of your income is protected until you can return to work or you reach retirement age.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-2",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-2",
              "text": "Employees may purchase disability insurance on a voluntary basis.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-3",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-3",
              "text": "Voluntary STD: 60% of your income, up to $1,500/week. 7-day elimination period. Maximum benefit period of 12 weeks.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-4",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-4",
              "text": "Voluntary LTD: 60% of your income, up to $6,500/month. 90-day elimination period. Payments last until you are no longer disabled or reach Social Security Normal Retirement Age, whichever is sooner.",
              "marks": []
            }
          ],
          "markDefs": []
        }
      ],
