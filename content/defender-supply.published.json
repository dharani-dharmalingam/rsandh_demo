    {
      "_id": "desu-ch-survivor-benefits",
      "title": "Survivor Benefits",
      "description": "Basic and voluntary life and AD&D insurance through Unum to protect your family financially.",
      "slug": "survivor-benefits",
      "icon": "umbrella",
      "content": [
        {
          "_type": "block",
          "_key": "block-0",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-0",
              "text": "LEHR provides employees with Basic Life and AD&D insurance as part of your basic coverage through Unum, which guarantees that your spouse or other designated survivor(s) continue to receive benefits after death.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-1",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-1",
              "text": "Your Basic Life and AD&D insurance benefit is $10,000. If you are a full-time employee, you automatically receive Life and AD&D insurance even if you waive other coverage.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-2",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-2",
              "text": "You may purchase Voluntary Life/AD&D insurance for yourself in $10,000 increments, up to a maximum of lesser of 5x earnings or $500,000. EOI is required over $100,000.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-3",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-3",
              "text": "Voluntary Life/AD&D insurance is available in $5,000 increments for your spouse, up to lesser of employee amount or $250,000. EOI is required over $25,000.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-4",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-4",
              "text": "You may purchase Voluntary Life/AD&D insurance in $2,000 increments for your child(ren), up to $10,000. EOI is not required.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-5",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-5",
              "text": "Note: Benefits subject to age reduction schedule — 65% at age 65, 50% at age 70.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-6",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-6",
              "text": "Voluntary AD&D Insurance: $0.020 per $1,000 coverage (monthly).",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-7",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-7",
              "text": "Voluntary Child Life Insurance: $0.400 per $1,000 coverage (monthly).",
              "marks": []
            }
          ],
          "markDefs": []
        }
      ],
      "tables": [
