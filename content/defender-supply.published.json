    {
      "_id": "desu-ch-overview-of-available-plans",
      "title": "Overview of Available Plans",
      "description": "A summary of all benefit options available to Defender Supply employees in 2025.",
      "slug": "overview-of-available-plans",
      "icon": "file-text",
      "content": [
        {
          "_type": "block",
          "_key": "block-0",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-0",
              "text": "Defender Supply offers a comprehensive benefits package for 2025 covering medical, dental, vision, life and AD&D insurance, short- and long-term disability, and a Health Savings Account.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-1",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-1",
              "text": "Medical coverage is provided by UHC and includes three plan options: HDHP, Base Copay, and Buy-Up Copay, all available nationwide.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-2",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-2",
              "text": "Voluntary dental and vision coverage is also available through UHC.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-3",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-3",
              "text": "Life, AD&D, and disability coverage is provided through Unum. Basic Life and AD&D insurance of $10,000 is provided automatically to all full-time employees.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-4",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-4",
              "text": "Employees enrolled in the HDHP may contribute to a Health Savings Account (HSA) through Optum.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-5",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-5",
              "text": "This brochure is intended to describe the eligibility requirements, enrollment procedures and coverage effective dates for the benefits offered by the Company. It is not a legal Plan document. Full details are contained in the Summary Plan Descriptions (SPDs).",
              "marks": []
            }
          ],
          "markDefs": []
        }
      ],
      "order": 2
    },
