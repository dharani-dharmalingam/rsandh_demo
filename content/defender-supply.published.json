          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-1",
              "text": "The elections you make are effective 1st of the month following 60 days of employment.",
              "marks": []
            }
          ],
          "markDefs": []
        },
        {
          "_type": "block",
          "_key": "block-2",
          "style": "normal",
          "children": [
            {
              "_type": "span",
              "_key": "span-2",
              "text": "This is an ACTIVE enrollment! Current benefit elections will not roll over. All eligible employees must make elections in order to receive benefits in 2025.",
