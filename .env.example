# Admin
ADMIN_TOKEN=                      # Secret token for admin access

# Local dev: fallback employer slug when no subdomain is available
NEXT_PUBLIC_DEFAULT_EMPLOYER=rs-h

# LlamaParse / LlamaCloud (for AI extraction pipeline)
LLAMA_CLOUD_API_KEY=
LLAMA_CLOUD_PROJECT_ID=

# Optional: transform step
OPENAI_API_KEY=

# Supabase (PDF + logo in bucket "employer-assets"; extracted content in table "content_drafts")
# Storage: create bucket "employer-assets" and set it to Public.
# Table: run scripts/supabase-content-drafts-table.sql once in Supabase SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=          # From Supabase Dashboard → Settings → API → service_role (paste in .env.local)

# GitHub (for serverless → Git commit pipeline: commit extracted content to repo so Vercel deploys)
# Create a Personal Access Token with repo scope. Repo format: owner/repo (e.g. acolyteai/rsandh-hub)
GITHUB_TOKEN=
GITHUB_REPO=
